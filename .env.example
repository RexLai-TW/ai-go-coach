# Copy to .env and fill in. Required variables are validated at server startup.

# --- Required ---
# Secret used to sign session cookies.
JWT_SECRET=
# MySQL connection string, e.g. mysql://user:pass@host:3306/dbname
DATABASE_URL=
# OAuth server base URL used by the auth flow.
OAUTH_SERVER_URL=

# --- Optional ---
# App identifier surfaced to the client.
VITE_APP_ID=
# OpenId of the owner account; granted the admin role on sign-in.
OWNER_OPEN_ID=
# Built-in (fallback) OpenAI-compatible LLM endpoint and key. Used when a user
# has not configured their own provider in Settings.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
# Port the server listens on (defaults to 3000).
PORT=3000
